{
  "name": "saizeriya",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "cd packages/server && bun --watch src/main.ts",
    "dev:app": "bun run --cwd apps/betterzeriya dev",
    "betterzeriya:build": "bun run --cwd packages/client build && bun run --cwd apps/betterzeriya build",
    "betterzeriya:build:vercel": "bun run --cwd packages/client build && cd apps/betterzeriya && VERCEL=1 bun run build && mkdir -p ../../.vercel && rm -rf ../../.vercel/output && cp -R .vercel/output ../../.vercel/output",
    "betterzeriya:start": "node apps/betterzeriya/build",
    "build": "bun run betterzeriya:build",
    "start": "HOST=localhost node apps/betterzeriya/build",
    "cli": "bun --cwd packages/client cli.ts",
    "format": "vp fmt . --write",
    "format:check": "vp fmt . --check",
    "lint": "vp lint .",
    "lint:fix": "vp lint . --fix",
    "check": "vp check .",
    "check:fix": "vp check --fix",
    "test": "vp test",
    "test:watch": "vp test watch"
  },
  "dependencies": {
    "p-limit": "^7.3.0"
  },
  "devDependencies": {
    "vite-plus": "^0.1.20"
  },
  "peerDependencies": {
    "typescript": "^6"
  }
}
